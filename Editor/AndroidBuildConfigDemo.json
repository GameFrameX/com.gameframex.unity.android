{
  "providerName": "Demo SDK",
  "mavenRepositories": [
    {
      "name": "DemoMavenRepo",
      "url": "https://maven.example.com/repository/maven-releases/"
    }
  ],
  "gradleWrapper": {
    "distributionUrl": "https\\://services.gradle.org/distributions/gradle-8.4-bin.zip"
  },
  "launcher": {
    "compileSdkVersion": "34",
    "buildToolsVersion": "34.0.0",
    "minSdkVersion": "24",
    "targetSdkVersion": "34",
    "applicationId": "com.example.demo",
    "versionName": "1.0.0",
    "dependencies": [
      {
        "configuration": "implementation",
        "notation": "com.example:sdk-analytics:2.0.0"
      }
    ],
    "permissions": [
      "android.permission.INTERNET",
      "android.permission.ACCESS_NETWORK_STATE"
    ],
    "metaData": [
      {
        "name": "com.example.analytics.APP_ID",
        "value": "your_app_id"
      }
    ],
    "signingConfig": {
      "storeFile": "keystore/release.jks",
      "storePassword": "your_store_password",
      "keyAlias": "release",
      "keyPassword": "your_key_password"
    }
  },
  "unityLibrary": {
    "compileSdkVersion": "34",
    "buildToolsVersion": "34.0.0",
    "minSdkVersion": "24",
    "targetSdkVersion": "34",
    "dependencies": [
      {
        "configuration": "implementation",
        "notation": "com.example:sdk-core:2.0.0"
      }
    ],
    "permissions": [
      "android.permission.INTERNET"
    ],
    "metaData": []
  },
  "fileCopies": {
    "libs/sdk-analytics.aar": "launcher/libs/sdk-analytics.aar"
  },
  "directoryCopies": {
    "jniLibs": "launcher/jniLibs"
  },
  "assetPacks": [
    {
      "name": "base-assets",
      "deliveryType": "install-time",
      "streamingAssetsPath": "BaseAssets"
    },
    {
      "name": "dlc-pack",
      "deliveryType": "on-demand",
      "streamingAssetsPath": "DLC"
    }
  ]
}
